
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Turnos Manzano application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "name": {
          "type": "string",
          "description": "The user's first name."
        },
        "lastName": {
          "type": "string",
          "description": "The user's last name."
        },
        "dni": {
          "type": "string",
          "description": "The user's DNI (National Identity Document)."
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "The role of the user, determining their permissions.",
          "enum": ["manzano_admin", "license_admin", "super_admin"]
        }
      },
      "required": [
        "id",
        "name",
        "lastName",
        "dni",
        "phone",
        "email",
        "role"
      ]
    },
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents an appointment for a museum visit.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the appointment."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N Appointment)"
        },
        "date": {
          "type": "string",
          "description": "The date of the appointment in YYYY-MM-DD format.",
          "format": "date"
        },
        "startTime": {
          "type": "string",
          "description": "The start time of the appointment."
        },
        "endTime": {
          "type": "string",
          "description": "The end time of the appointment."
        },
        "responsibleName": {
            "type": "string",
            "description": "Name of the person responsible for the group."
        },
        "schoolName": {
            "type": "string",
            "description": "Name of the school or institution visiting."
        },
        "visitorCount": {
            "type": "number",
            "description": "Number of people in the visiting group."
        },
        "status": {
            "type": "string",
            "description": "The status of the appointment.",
            "enum": ["pending", "confirmed", "cancelled"]
        },
        "paid": {
            "type": "boolean",
            "description": "Whether the appointment has been paid."
        },
        "createdAt": {
            "type": "string",
            "description": "The timestamp when the appointment was created.",
            "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "date",
        "startTime",
        "endTime",
        "responsibleName",
        "schoolName",
        "visitorCount",
        "status",
        "createdAt"
      ]
    },
    "LicenseAppointment": {
      "title": "LicenseAppointment",
      "type": "object",
      "description": "Represents an appointment for a driver's license procedure.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "procedureType": { "type": "string", "description": "The type of license procedure (e.g., new, renewal)." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "documents": {
          "type": "object",
          "description": "A map of document IDs to their download URLs in Firebase Storage.",
          "additionalProperties": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "required": ["id", "userId", "date", "startTime", "endTime", "procedureType", "status", "createdAt"]
    },
    "ScheduleConfiguration": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ScheduleConfiguration",
      "type": "object",
      "description": "Represents the configuration for available museum appointment days and times.",
      "properties": {
        "days": {
          "type": "object",
          "properties": {
            "monday": {"$ref": "#/entities/DayConfiguration"},
            "tuesday": {"$ref": "#/entities/DayConfiguration"},
            "wednesday": {"$ref": "#/entities/DayConfiguration"},
            "thursday": {"$ref": "#/entities/DayConfiguration"},
            "friday": {"$ref": "#/entities/DayConfiguration"},
            "saturday": {"$ref": "#/entities/DayConfiguration"},
            "sunday": {"$ref": "#/entities/DayConfiguration"}
          }
        }
      },
      "required": ["days"]
    },
    "LicenseScheduleConfiguration": {
      "title": "LicenseScheduleConfiguration",
      "type": "object",
      "description": "Represents the configuration for available driver's license appointment days and times.",
      "properties": {
        "days": {
          "type": "object",
          "properties": {
            "monday": {"$ref": "#/entities/DayConfiguration"},
            "tuesday": {"$ref": "#/entities/DayConfiguration"},
            "wednesday": {"$ref": "#/entities/DayConfiguration"},
            "thursday": {"$ref": "#/entities/DayConfiguration"},
            "friday": {"$ref": "#/entities/DayConfiguration"},
            "saturday": {"$ref": "#/entities/DayConfiguration"},
            "sunday": {"$ref": "#/entities/DayConfiguration"}
          }
        }
      },
      "required": ["days"]
    },
    "DayConfiguration": {
        "title": "DayConfiguration",
        "type": "object",
        "properties": {
            "enabled": { "type": "boolean" },
            "slots": {
                "type": "array",
                "items": { "$ref": "#/entities/TimeSlot" }
            }
        },
        "required": ["enabled", "slots"]
    },
    "TimeSlot": {
        "title": "TimeSlot",
        "type": "object",
        "properties": {
            "startTime": { "type": "string" },
            "endTime": { "type": "string" },
            "capacity": { "type": "number" }
        },
        "required": ["startTime", "endTime", "capacity"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles. Path-based ownership enables straightforward security rules based on `request.auth.uid`.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user."
            }
          ]
        }
      },
      {
        "path": "/appointments/{appointmentId}",
        "definition": {
          "entityName": "Appointment",
          "schema": {
            "$ref": "#/backend/entities/Appointment"
          },
          "description": "Stores all museum appointments from all users. Access should be restricted to 'manzano_admin' role.",
          "params": [
            {
              "name": "appointmentId",
              "description": "The unique identifier of the appointment."
            }
          ]
        }
      },
      {
        "path": "/licenseAppointments/{licenseAppointmentId}",
        "definition": {
          "entityName": "LicenseAppointment",
          "schema": { "$ref": "#/backend/entities/LicenseAppointment" },
          "description": "Stores all driver's license appointments. Access should be restricted to 'license_admin' role.",
          "params": [{"name": "licenseAppointmentId", "description": "The unique identifier of the license appointment."}]
        }
      },
      {
        "path": "/scheduleConfigurations/{scheduleConfigurationId}",
        "definition": {
          "entityName": "ScheduleConfiguration",
          "schema": {
            "$ref": "#/backend/entities/ScheduleConfiguration"
          },
          "description": "Stores configurations for available museum appointment days and times. Access should be restricted to 'manzano_admin' role.",
          "params": [
            {
              "name": "scheduleConfigurationId",
              "description": "The unique identifier for the schedule configuration."
            }
          ]
        }
      },
      {
        "path": "/licenseScheduleConfigurations/{licenseScheduleConfigurationId}",
        "definition": {
          "entityName": "LicenseScheduleConfiguration",
          "schema": { "$ref": "#/backend/entities/LicenseScheduleConfiguration" },
          "description": "Stores configurations for available driver's license appointment times. Access should be restricted to 'license_admin' role.",
          "params": [{"name": "licenseScheduleConfigurationId", "description": "The unique identifier for the license schedule configuration."}]
        }
      }
    ],
    "reasoning": "The Firestore structure is designed for clarity, security, and role-based access. User data is central. Museum and license appointments (and their configurations) are stored in separate top-level collections to enforce strict access control via security rules based on user roles."
  }
}
