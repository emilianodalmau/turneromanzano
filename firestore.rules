rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regla temporal: Permite la lectura y escritura en todos los documentos
    // a cualquier cliente, autenticado o no.
    // ¡ADVERTENCIA! Esto es inseguro y solo debe usarse para depuración.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
