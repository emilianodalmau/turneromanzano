
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /appointments/{appointmentId} {
      allow create: if true;
      allow read, list: if request.auth != null; // To be refined with roles
      allow update, delete: if request.auth != null; // To be refined with roles
    }

    match /scheduleConfigurations/{scheduleId} {
      allow read: if true;
      allow write: if request.auth != null; // To be refined with roles
    }

    // Rules for new license module
    match /licenseAppointments/{licenseAppointmentId} {
      allow create: if true;
      allow read, list: if true; // Allow public read for availability check
      allow update, delete: if request.auth != null; // To be refined with roles
    }

    match /licenseScheduleConfigurations/{licenseScheduleId} {
      allow read: if true;
      allow write: if request.auth != null; // To be refined with roles
    }

    // Rules for presential attention system
    match /areas/{areaId} {
      allow read: if true;
      allow write: if request.auth != null; // To be refined with roles (super_admin)
    }

    match /desks/{deskId} {
      allow read: if true;
      allow write: if request.auth != null; // To be refined with roles (super_admin, agents)
    }

    match /queueTickets/{ticketId} {
      allow read, list: if true; // Public read for screens, agent list
      allow create: if true; // Public create for totem
      allow update: if request.auth != null; // Only agents can update
    }
  }
}

    