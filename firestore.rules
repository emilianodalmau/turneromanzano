
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to read a user's profile from the /users collection
    function getUserProfile(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    // Helper function to check for a role from a user's profile document
    function hasRole(role) {
      // Ensure user is authenticated and has a profile
      return request.auth != null && getUserProfile(request.auth.uid).role == role;
    }

    function isSuperAdmin() {
      // A user is a super admin if their profile document says so.
      return hasRole('super_admin');
    }

    function isManzanoAdmin() {
      // A user is a Manzano admin if their profile says so, or if they are a super admin.
      return hasRole('manzano_admin') || isSuperAdmin();
    }

    function isLicenseAdmin() {
      // A user is a License admin if their profile says so, or if they are a super admin.
      return hasRole('license_admin') || isSuperAdmin();
    }
    
    match /users/{userId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update: if request.auth.uid == userId || isSuperAdmin();
      // A user can delete themselves, or a super_admin can delete any user.
      allow delete: if request.auth.uid == userId || isSuperAdmin();
    }

    match /guests/{guestId} {
      allow create: if true;
      // Allow any authenticated user to manage guests, access is controlled by the app UI
      allow list, read, update: if request.auth != null;
    }

    match /appointments/{appointmentId} {
      allow create: if true;
      allow list, read: if true;
      allow update, delete: if request.auth != null && isManzanoAdmin();
    }

    match /scheduleConfigurations/{scheduleId} {
      allow read: if true;
      allow write: if request.auth != null && isManzanoAdmin();
    }

    match /licenseAppointments/{licenseAppointmentId} {
      allow create: if true;
      // Allow any authenticated user to manage license appointments, access is controlled by the app UI
      allow list, read, update, delete: if request.auth != null;
    }

    match /licenseScheduleConfigurations/{licenseScheduleId} {
      allow read: if true;
      allow write: if request.auth != null && isLicenseAdmin();
    }

    match /areas/{areaId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /desks/{deskId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /queueTickets/{ticketId} {
      allow list, read: if true;
      allow create: if true;
      allow update: if request.auth != null; 
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isManzanoAdmin();
    }

    match /appConfiguration/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
