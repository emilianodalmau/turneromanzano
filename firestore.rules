rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow any authenticated user (admin) full access to user profiles.
    match /users/{userId} {
      allow read, write, create, update, delete: if request.auth != null;
    }

    // Allow any authenticated user (admin) full access to appointments.
    match /users/{userId}/appointments/{appointmentId} {
      allow read, write, create, update, delete: if request.auth != null;
    }

    // Allow collection group queries on appointments for authenticated users.
    match /{path=**}/appointments/{appointmentId} {
       allow get, list: if request.auth != null;
    }

    // Allow any authenticated user (admin) to manage schedule configurations.
    match /scheduleConfigurations/{docId} {
      allow read, write, create, update, delete: if request.auth != null;
    }
  }
}
