rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read, update, or delete their own profile.
    // Admins (any authenticated user in this demo) can create new users.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      // Allow any authenticated user (admin) to create user profiles.
      allow create: if request.auth != null;
    }

    // A user can manage their own appointments.
    match /users/{userId}/appointments/{appointmentId} {
      allow read, list, create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Admins can read all appointments for management purposes.
    // This uses a collection group query.
    match /{path=**}/appointments/{appointmentId} {
        // For now, allow any authenticated user to list all appointments (for admin panel)
        // In a real app, you'd check for an admin custom claim.
       allow get, list: if request.auth != null;
    }

    // Schedule configuration is publicly readable but only writable by admins.
    match /scheduleConfigurations/{docId} {
      allow read: if request.auth != null;
    }
    
    match /scheduleConfigurations/main_schedule {
        // In a real app, you'd check for an admin custom claim.
        allow write: if request.auth != null;
    }
  }
}
