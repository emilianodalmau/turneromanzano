rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Permite escritura y lectura pública para comprobantes de pago.
    // Esto es necesario para que el usuario pueda subir el comprobante
    // y el administrador pueda verlo.
    match /comprobantesPago/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Permite escritura y lectura pública para documentos de licencias.
    match /license-documents/{allPaths=**} {
      allow read, write: if true;
    }

    // La carpeta de prueba se mantiene por si necesitamos futuras verificaciones.
    match /test-uploads/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
